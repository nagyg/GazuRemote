# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/

# GazuRemote user config (contains credentials – never commit!)
~/GazuRemote/
user_config.json

# Bundled Python runtime (large binary – distribute separately)
Python312/*
# The Gazu folder IS committed (contains scripts only – Lib/ is pip-installed at runtime)
!Python312/Gazu/
Python312/Gazu/*
!Python312/Gazu/scripts/

# Gazu Lib (extracted at install time from Python312/Gazu/Lib.zip)
Python312/Gazu/Lib/

# Nuke third-party plugins (installed locally – not committed)
dcc/Nuke/Plugins/*
!dcc/Nuke/Plugins/.gitkeep

# Fusion third-party plugins (installed locally – not committed)
dcc/Fusion/Plugins/*
!dcc/Fusion/Plugins/.gitkeep

# Fusion Reactor package manager (large binary content – not committed)
dcc/Fusion/Reactor/**
# Keep only the Reactor config file
!dcc/Fusion/Reactor/Deploy/
!dcc/Fusion/Reactor/Deploy/Config/
!dcc/Fusion/Reactor/Deploy/Config/Reactor.fu

# Nuke user profile directory (local user data – not committed)
dcc/nuke/.nuke/

# Generated thumbnails (local cache – not committed)
thumbnails/

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
Thumbs.db
.DS_Store

# Logs
*.log
